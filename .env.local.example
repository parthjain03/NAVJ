# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Gmail address used to SEND the contact form emails
GMAIL_USER=adeepjain.ca@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one: Google Account → Security → 2-Step Verification → App passwords
# Create an app password for "Mail" → use the 16-character code here
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address where you want to RECEIVE contact form submissions
# Change this to your domain email once you have it (e.g. adeep@navjco.com)
CONTACT_EMAIL_TO=adeepjain.ca@gmail.com
